# package-lock.json no se commitea: generado en Windows queda incompleto para
# la rama wasm de @tailwindcss/oxide (faltan @emnapi/core y @emnapi/runtime de
# Linux) y rompe `npm ci` en el build de Cloudflare. Sin lock, el CI usa
# `npm install` y resuelve bien en Linux. Regenerar un lock correcto en Linux/CI
# si se quiere reproducibilidad exacta.
package-lock.json
.env
.env.*

